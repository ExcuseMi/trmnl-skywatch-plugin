# Skywatch Backend Configuration

# Set to true to restrict access only to TRMNL server IPs
ENABLE_IP_WHITELIST=false

# Port to expose the service on
PORT=8145

# Cache TTL in seconds (default: 840 = 14 minutes, matches TRMNL refresh interval)
CACHE_TTL_SECONDS=840

# User-Agent header sent to airplanes.live API
USER_AGENT=TRMNL-Skywatch-Plugin/1.0

# Minimum seconds between API calls
COOLDOWN_SECONDS=10
