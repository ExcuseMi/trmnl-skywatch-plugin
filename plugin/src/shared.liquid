{% template main %}
{% if data.fetched_at %}
  {% assign local_timestamp = data.fetched_at | date: "%s" | plus: trmnl.user.utc_offset %}
{% else %}
  {% assign local_timestamp = 'now' | date: "%s" | plus: trmnl.user.utc_offset %}
{% endif %}

{% if data.planes == blank %}

<div class="layout layout--col gap--small">
  <div class="description lg:description--large">No aircraft data — check your latitude and longitude settings.</div>
</div>
<div class="title_bar">
  <span class="title">{{ trmnl.plugin_settings.instance_name | default: "Sky Watch"}}</span>
</div>

{% else %}

{% assign instance_id = "inst_" | append_random %}

<div class="layout layout--stretch gap--none m--0 p--0" data-instance="{{ instance_id }}">
  <svg class="image image-dither image--fill w--full h--full rounded"
       viewBox="0 0 768 768"
       preserveAspectRatio="xMidYMid slice">
    <defs id="sky-defs-{{ instance_id }}"></defs>
    <g id="sky-tiles-{{ instance_id }}"></g>
    <g id="sky-airports-{{ instance_id }}"></g>
    <g id="sky-center-{{ instance_id }}"></g>
    <g id="sky-outlines-{{ instance_id }}"></g>
    <g id="sky-planes-{{ instance_id }}"></g>
  </svg>
</div>

<div class="title_bar">
  <svg class="h--8 dark:hidden" viewBox="0 0 36 36" preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg" fill="black"><path d="M6.25,11.5,12,13.16l6.32-4.59-9.07.26A.52.52,0,0,0,9,8.91L6.13,10.56A.51.51,0,0,0,6.25,11.5Z"/><path d="M34.52,6.36,28.22,5a3.78,3.78,0,0,0-3.07.67L6.12,19.5l-4.57-.2a1.25,1.25,0,0,0-.83,2.22l4.45,3.53a.55.55,0,0,0,.53.09c1.27-.49,6-3,11.59-6.07l1.12,11.51a.55.55,0,0,0,.9.37l2.5-2.08a.76.76,0,0,0,.26-.45l2.37-13.29c4-2.22,7.82-4.37,10.51-5.89A1.55,1.55,0,0,0,34.52,6.36Z"/></svg>
<svg class="h--8 dark:block hidden" viewBox="0 0 36 36" preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg" fill="black" style="filter: invert(1);"><path d="M6.25,11.5,12,13.16l6.32-4.59-9.07.26A.52.52,0,0,0,9,8.91L6.13,10.56A.51.51,0,0,0,6.25,11.5Z"/><path d="M34.52,6.36,28.22,5a3.78,3.78,0,0,0-3.07.67L6.12,19.5l-4.57-.2a1.25,1.25,0,0,0-.83,2.22l4.45,3.53a.55.55,0,0,0,.53.09c1.27-.49,6-3,11.59-6.07l1.12,11.51a.55.55,0,0,0,.9.37l2.5-2.08a.76.76,0,0,0,.26-.45l2.37-13.29c4-2.22,7.82-4.37,10.51-5.89A1.55,1.55,0,0,0,34.52,6.36Z"/></svg>
  <span class="title">{{ trmnl.plugin_settings.instance_name | default: "SkyWatch" }}</span>
  <span class="instance md:portrait:hidden">{% if trmnl.plugin_settings.custom_fields_values.address != blank %}{{ trmnl.plugin_settings.custom_fields_values.address }} · {% endif %}{% if trmnl.plugin_settings.custom_fields_values.unit == "imperial" %}{{ local_timestamp | date: "%-I:%M %p" }}{% else %}{{ local_timestamp | date: "%H:%M" }}{% endif %}</span>
</div>

<script>
(function () {
  var instanceId = '{{ instance_id }}';
  var planes     = {{ data.planes | json }};
  var airports   = {{ data.airports | json | default: "[]" }};
  var total      = {{ data.total | default: 0 }};
  var centerLat  = parseFloat('{{ data.lat | default: 51.5074 }}');
  var centerLon  = parseFloat('{{ data.lon | default: -0.1278 }}');
  var mapStyle   = 'cartodb_dark';
  var unit       = '{{ trmnl.plugin_settings.custom_fields_values.unit | default: "metric" }}';
  var darkMode   = '{{ trmnl.plugin_settings.dark_mode }}' === 'yes';
  var view       = {{ view | default: 1 }};

  var S = 768, T = 256;
  var z = 10;

  function calculateOptimalZoom() {
    if (!planes || planes.length === 0) return 10;
    var dists = planes
      .filter(function(p) { return p.lat != null && p.lon != null; })
      .map(function(p) {
        return Math.sqrt(Math.pow(p.lat - centerLat, 2) + Math.pow(p.lon - centerLon, 2));
      })
      .sort(function(a, b) { return a - b; });

    if (dists.length === 0) return 10;
    // Use farthest of up to 8 closest planes, plus 20% padding
    var target = dists[Math.min(7, dists.length - 1)] * 1.2;
    // Thresholds: plane should land within 75% of screen edge
    // half-widths: z10=0.527°, z9=1.055°, z8=2.109°, z7=4.219°, z6=8.438°
    if (target < 0.40) return 10;
    if (target < 0.79) return 9;
    if (target < 1.58) return 8;
    if (target < 3.16) return 7;
    return 6;
  }

  z = calculateOptimalZoom();

  function init() {
    var container = document.querySelector('.layout[data-instance="' + instanceId + '"]');
    if (!container) return;

    var ns = 'http://www.w3.org/2000/svg';

    function ll2tf(lat, lon) {
      var n  = Math.pow(2, z);
      var lr = lat * Math.PI / 180;
      return {
        x: (lon + 180) / 360 * n,
        y: (1 - Math.log(Math.tan(lr) + 1 / Math.cos(lr)) / Math.PI) / 2 * n
      };
    }

    var ct = ll2tf(centerLat, centerLon);
    var cx = Math.round(ct.x);
    var cy = Math.round(ct.y);

    function ll2px(lat, lon) {
      var t = ll2tf(lat, lon);
      return {
        x: (t.x - ct.x) * T + S / 2,
        y: (t.y - ct.y) * T + S / 2
      };
    }

    function formatAltitude(val) {
      if (val == null || val === 'ground') return val === 'ground' ? 'GND' : '—';
      var n = Math.round(+val); var s = n >= 1000 ? (Math.round(n/100)/10) + 'k' : n; return '↑ ' + s + (unit === 'imperial' ? ' ft' : ' m');
    }

    function formatSpeed(val) {
      if (val == null) return '—';
      return Math.round(+val).toLocaleString() + (unit === 'imperial' ? ' kt' : ' km/h');
    }

    function renderTiles() {
      var ml   = container.querySelector('#sky-tiles-' + instanceId);
      var defs = container.querySelector('#sky-defs-' + instanceId);
      if (!ml || !defs) return;
      for (var dy = -2; dy <= 1; dy++) {
        for (var dx = -2; dx <= 1; dx++) {
          var tx = cx + dx, ty = cy + dy;
          var px = (tx - ct.x) * T + S / 2;
          var py = (ty - ct.y) * T + S / 2;
          var pid = 'sk_' + instanceId + '_' + tx + '_' + ty;
          var patt = document.createElementNS(ns, 'pattern');
          patt.setAttribute('id', pid);
          patt.setAttribute('patternUnits', 'userSpaceOnUse');
          patt.setAttribute('x', px);  patt.setAttribute('y', py);
          patt.setAttribute('width', T); patt.setAttribute('height', T);
          var img = document.createElementNS(ns, 'image');
          var useDark = darkMode || mapStyle === 'cartodb_dark';
          var url = useDark
            ? ('https://a.basemaps.cartocdn.com/dark_all/'  + z + '/' + tx + '/' + ty + '.png')
            : ('https://a.basemaps.cartocdn.com/light_all/' + z + '/' + tx + '/' + ty + '.png');
          img.setAttributeNS('http://www.w3.org/1999/xlink', 'href', url);
          img.setAttribute('width', T); img.setAttribute('height', T);
          patt.appendChild(img);
          defs.appendChild(patt);
          var rect = document.createElementNS(ns, 'rect');
          rect.setAttribute('x', px);   rect.setAttribute('y', py);
          rect.setAttribute('width', T); rect.setAttribute('height', T);
          rect.setAttribute('fill', 'url(#' + pid + ')');
          ml.appendChild(rect);
        }
      }
    }

    function renderCenter() {
      var g = container.querySelector('#sky-center-' + instanceId);
      if (!g) return;
      var pos = ll2px(centerLat, centerLon);
      var useDark = darkMode || mapStyle === 'cartodb_dark';
      var fillColor = useDark ? '#ffffff' : '#000000';
      
      var path = document.createElementNS(ns, 'path');
      path.setAttribute('d', 'M8 0L0 6V8H1V15H4V10H7V15H15V8H16V6L14 4.5V1H11V2.25L8 0ZM9 10H12V13H9V10Z');
      path.setAttribute('transform', 'translate(' + pos.x.toFixed(0) + ',' + pos.y.toFixed(0) + ') scale(1.4) translate(-8,-8)');
      path.setAttribute('fill', fillColor);
      
      // Add a small shadow/glow for visibility on dark maps if needed
      if (useDark) {
        path.setAttribute('stroke', '#000000');
        path.setAttribute('stroke-width', '1');
      } else {
        path.setAttribute('stroke', '#ffffff');
        path.setAttribute('stroke-width', '1');
      }
      
      g.appendChild(path);
    }

