    }

    function renderPlanes() {
      var layer = container.querySelector('#sky-planes-' + instanceId);
      if (!layer) return;
      var sc = view >= 3 ? 1.1 : 1.6;
      var useDark = darkMode || mapStyle === 'cartodb_dark';
      var planeColor = useDark ? '#ffffff' : '#000000';
      var lineColor = useDark ? 'rgba(255,255,255,0.45)' : 'rgba(0,0,0,0.35)';
      var iconHalf = 12 * sc;

      // Pass 1: collect visible planes, dropping duplicates that overlap in pixel space
      var visible = [];
      (planes || []).filter(function(p) { return p.lat != null && p.lon != null; })
        .sort(function(a, b) {
          return (Math.pow(a.lat-centerLat,2)+Math.pow(a.lon-centerLon,2))
               - (Math.pow(b.lat-centerLat,2)+Math.pow(b.lon-centerLon,2));
        })
        .forEach(function(p) {
          var pos = ll2px(p.lat, p.lon);
          if (pos.x < -30 || pos.x > S+30 || pos.y < -30 || pos.y > S+30) return;
          var crowded = visible.some(function(v) {
            return Math.abs(v.x - pos.x) < iconHalf && Math.abs(v.y - pos.y) < iconHalf;
          });
          if (!crowded) visible.push({ p: p, x: pos.x, y: pos.y });
        });

      // Pre-register all plane icon footprints so labels won't overlap them
      var placedRects = visible.map(function(v) {
        return { x: v.x - iconHalf, y: v.y - iconHalf, w: iconHalf*2, h: iconHalf*2 };
      });

      function overlaps(r) {
        var pad = 4;
        return placedRects.some(function(e) {
          return r.x < e.x+e.w+pad && r.x+r.w+pad > e.x && r.y < e.y+e.h+pad && r.y+r.h+pad > e.y;
        });
      }

      function planeEdgePoint(cx, cy, track, tx, ty) {
        var angleToTarget = Math.atan2(ty-cy, tx-cx);
        var planeAngle = track * Math.PI / 180;
        var localAngle = angleToTarget - planeAngle;
        var hw = 10*sc, hh = 6*sc;
        var cosA = Math.cos(localAngle), sinA = Math.sin(localAngle);
        var den = Math.pow(cosA/hw,2) + Math.pow(sinA/hh,2);
        if (den === 0) return { x: cx, y: cy };
        var t = Math.min(1/Math.sqrt(den), Math.sqrt(hw*hw+hh*hh));
        var lx = t*cosA, ly = t*sinA;
        return {
          x: cx + lx*Math.cos(planeAngle) - ly*Math.sin(planeAngle),
          y: cy + lx*Math.sin(planeAngle) + ly*Math.cos(planeAngle)
        };
      }

      var ANCHORS = [
        {ax:1,ay:0},{ax:1,ay:-1},{ax:0,ay:-1},{ax:-1,ay:-1},
        {ax:-1,ay:0},{ax:-1,ay:1},{ax:0,ay:1},{ax:1,ay:1}
      ];
      var ANCHOR_R = iconHalf + 6;

      function altBgColor(alt) {
        if (alt === 'ground' || alt == null) return '#555555';
        var ft = unit === 'imperial' ? +alt : +alt / 0.3048;
        if (ft < 5000)  return '#444444';
        if (ft < 15000) return '#222222';
        if (ft < 30000) return '#111111';
        return '#000000';
      }

      function altPlaneColor(alt) {
        if (alt === 'ground' || alt == null) return useDark ? '#777777' : '#888888';
        var ft = unit === 'imperial' ? +alt : +alt / 0.3048;
        if (useDark) {
          if (ft < 5000)  return '#aaaaaa';
          if (ft < 15000) return '#cccccc';
          if (ft < 30000) return '#eeeeee';
          return '#ffffff';
        } else {
          if (ft < 5000)  return '#555555';
          if (ft < 15000) return '#333333';
          if (ft < 30000) return '#111111';
          return '#000000';
        }
      }

      var SQUAWK_LABELS = { '7500': 'HIJACK', '7600': 'NORDO', '7700': 'MAYDAY' };

      // Pass 2a: outlines — rendered below all fills so overlapping planes stay distinct
      var outlineLayer = container.querySelector('#sky-outlines-' + instanceId);
      visible.forEach(function(v) {
        var p = v.p, pos = { x: v.x, y: v.y };
        var track = p.track != null ? p.track : 0;
        var iconKey = getIconKey(p);
        var og = document.createElementNS(ns, 'g');
        og.setAttribute('transform', 'translate('+pos.x.toFixed(0)+','+pos.y.toFixed(0)+') rotate('+track+') scale('+sc+')');
        var ou = document.createElementNS(ns, 'use');
        ou.setAttributeNS('http://www.w3.org/1999/xlink', 'href', '#icon-'+iconKey+'-'+instanceId);
        ou.setAttribute('width','24'); ou.setAttribute('height','24');
        ou.setAttribute('x','-12'); ou.setAttribute('y','-12');
        ou.setAttribute('fill', 'none');
        ou.setAttribute('stroke', '#000000');
        ou.setAttribute('stroke-width', '2.5');
        og.appendChild(ou);
        if (outlineLayer) outlineLayer.appendChild(og);
        if (SQUAWK_LABELS[v.p.squawk]) {
          var ring = document.createElementNS(ns, 'circle');
          ring.setAttribute('cx', pos.x.toFixed(0));
          ring.setAttribute('cy', pos.y.toFixed(0));
          ring.setAttribute('r', (iconHalf + 6).toFixed(0));
          ring.setAttribute('fill', 'none');
          ring.setAttribute('stroke', '#000000');
          ring.setAttribute('stroke-width', '3');
          ring.setAttribute('stroke-dasharray', '4 3');
          if (outlineLayer) outlineLayer.appendChild(ring);
        }
      });

      // Pass 2b: fills and labels on top
      visible.forEach(function(v) {
        var p = v.p, pos = { x: v.x, y: v.y };
        var track = p.track != null ? p.track : 0;
        var iconKey = getIconKey(p);
        var g = document.createElementNS(ns, 'g');
        g.setAttribute('transform', 'translate('+pos.x.toFixed(0)+','+pos.y.toFixed(0)+') rotate('+track+') scale('+sc+')');
        var use = document.createElementNS(ns, 'use');
        use.setAttributeNS('http://www.w3.org/1999/xlink', 'href', '#icon-'+iconKey+'-'+instanceId);
        use.setAttribute('width','24'); use.setAttribute('height','24');
        use.setAttribute('x','-12'); use.setAttribute('y','-12');
        use.setAttribute('fill', SQUAWK_LABELS[p.squawk] ? (useDark ? '#ffffff' : '#000000') : altPlaneColor(p.alt_baro));
        use.setAttribute('stroke', 'none');
        g.appendChild(use);
        layer.appendChild(g);

        if (view <= 4) {
          var lbl = (p.flight || '').trim() || p.r || '';
          var desc = (p.desc || p.t || '').trim();
          var altStr = formatAltitude(p.alt_baro);
          var speedStr = p.gs != null ? ' · ' + formatSpeed(p.gs) : '';
          var altSpeedStr = altStr + speedStr;
          var rowCount = (lbl ? 1 : 0) + (desc ? 1 : 0) + 1;
          var blockH = rowCount * 14;
          var maxWidth = Math.max(lbl.length*8+4, desc.length*7+4, altSpeedStr.length*6+4, 20);
          var anchor = null;
          for (var i = 0; i < ANCHORS.length; i++) {
            var a = ANCHORS[i];
            var lx = pos.x + a.ax*ANCHOR_R - (a.ax < 0 ? maxWidth : (a.ax === 0 ? maxWidth/2 : 0));
            var ly = pos.y + a.ay*ANCHOR_R - (a.ay < 0 ? blockH : (a.ay === 0 ? blockH/2 : 0));
            var r = { x: lx, y: ly, w: maxWidth, h: blockH };
            if (!overlaps(r)) { anchor = { x: lx, y: ly, r: r }; break; }
          }
          if (!anchor) return;
          placedRects.push(anchor.r);
          var lx = anchor.x, ly = anchor.y;
          var labelCX = lx+maxWidth/2, labelCY = ly+(lbl?14:0)+7;
          var edge = planeEdgePoint(pos.x, pos.y, track, labelCX, labelCY);
          var line = document.createElementNS(ns, 'line');
          line.setAttribute('x1',edge.x.toFixed(0)); line.setAttribute('y1',edge.y.toFixed(0));
          line.setAttribute('x2',labelCX.toFixed(0)); line.setAttribute('y2',labelCY.toFixed(0));
          line.setAttribute('stroke',lineColor); line.setAttribute('stroke-width','1.5');
          layer.appendChild(line);
          var bgColor = altBgColor(p.alt_baro);
          var pad = 4;

          function measureText(text, fontSize, bold) {
            return Math.ceil(text.length * parseInt(fontSize) * (bold ? 0.68 : 0.58));
          }

          function addRow(text, y, fontSize, fontWeight, textFill, rowH) {
            var w = measureText(text, fontSize, !!fontWeight) + pad;
            var bg = document.createElementNS(ns, 'rect');
            bg.setAttribute('x', lx.toFixed(0));
            bg.setAttribute('y', (y - rowH + 3).toFixed(0));
            bg.setAttribute('width', w);
            bg.setAttribute('height', rowH);
            bg.setAttribute('fill', bgColor);
            bg.setAttribute('rx', '2');
            layer.appendChild(bg);
            var t = document.createElementNS(ns, 'text');
            t.setAttribute('x', (lx + pad/2).toFixed(0));
            t.setAttribute('y', y.toFixed(0));
            t.setAttribute('font-size', fontSize);
            if (fontWeight) t.setAttribute('font-weight', fontWeight);
            t.setAttribute('font-family', 'var(--title-bar-font-family), var(--title-font-family), "NicoClean", monospace');
            t.setAttribute('fill', textFill);
            t.textContent = text;
            layer.appendChild(t);
          }

          var squawkLabel = SQUAWK_LABELS[p.squawk] || '';
          if (!lbl && !desc && !squawkLabel) return;
          var rowY = ly;
          if (squawkLabel) { rowY += 14; addRow(squawkLabel, rowY, '12', 'bold', '#ffffff', 13); }
          if (lbl) { rowY += 14; addRow(lbl, rowY, '12', 'bold', '#ffffff', 13); }
          if (desc) { rowY += 14; addRow(desc, rowY, '11', null, '#cccccc', 13); }
          rowY += 14; addRow(altSpeedStr, rowY, '11', null, '#ffffff', 13);
        }
      });
    }

    function renderAirports() {
      var layer = container.querySelector('#sky-airports-' + instanceId);
      if (!layer || !airports || airports.length === 0) return;
      var useDark = darkMode || mapStyle === 'cartodb_dark';
      airports.forEach(function(a) {
        if (a.lat == null || a.lon == null) return;
        var pos = ll2px(a.lat, a.lon);
        if (pos.x < -20 || pos.x > S + 20 || pos.y < -20 || pos.y > S + 20) return;

        var r = 6;
        var strokeW = 2;
        var color = useDark ? '#ffffff' : '#000000';

        // Outer circle
        var circle = document.createElementNS(ns, 'circle');
        circle.setAttribute('cx', pos.x.toFixed(1));
        circle.setAttribute('cy', pos.y.toFixed(1));
        circle.setAttribute('r', r);
        circle.setAttribute('fill', 'none');
        circle.setAttribute('stroke', color);
        circle.setAttribute('stroke-width', strokeW);
        layer.appendChild(circle);

        // Cross lines
        [[[0, -r - 3], [0, r + 3]], [[-r - 3, 0], [r + 3, 0]]].forEach(function(seg) {
          var line = document.createElementNS(ns, 'line');
          line.setAttribute('x1', (pos.x + seg[0][0]).toFixed(1));
          line.setAttribute('y1', (pos.y + seg[0][1]).toFixed(1));
          line.setAttribute('x2', (pos.x + seg[1][0]).toFixed(1));
          line.setAttribute('y2', (pos.y + seg[1][1]).toFixed(1));
          line.setAttribute('stroke', color);
          line.setAttribute('stroke-width', strokeW);
          layer.appendChild(line);
        });

        // ICAO label
        var code = a.iata || a.icao || '';
        if (code && view <= 3) {
          var t = document.createElementNS(ns, 'text');
          t.setAttribute('x', (pos.x + r + 3).toFixed(1));
          t.setAttribute('y', (pos.y - r - 2).toFixed(1));
          t.setAttribute('font-size', '9');
          t.setAttribute('font-family', 'var(--title-bar-font-family), "NicoClean", monospace');
          t.setAttribute('fill', color);
          t.setAttribute('opacity', '0.7');
          t.textContent = code;
          layer.appendChild(t);
        }
      });
    }

    setupSymbols();
    renderTiles();
    renderAirports();
    renderCenter();
    renderPlanes();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>
{% endif %}
{% endtemplate %}