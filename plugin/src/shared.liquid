    function setupSymbols() {
      var defs = container.querySelector('#sky-defs-' + instanceId);
      Object.keys(ICONS).forEach(function(key) {
        var icon = ICONS[key];
        var sym = document.createElementNS(ns, 'symbol');
        sym.setAttribute('id', 'icon-' + key + '-' + instanceId);
        sym.setAttribute('viewBox', icon.v);
        var paths = icon.paths || [{ d: icon.d, f: icon.f }];
        paths.forEach(function(pd) {
          var g = document.createElementNS(ns, 'g');
          if (pd.f) g.setAttribute('transform', pd.f);
          var path = document.createElementNS(ns, 'path');
          path.setAttribute('d', pd.d);
          path.setAttribute('stroke', 'inherit');
          path.setAttribute('stroke-width', 'inherit');
          path.setAttribute('vector-effect', 'non-scaling-stroke');
          path.setAttribute('style', 'paint-order: stroke fill');
          g.appendChild(path);
          sym.appendChild(g);
        });
        defs.appendChild(sym);
      });
    }

